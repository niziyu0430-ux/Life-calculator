# 忽略系统文件
.DS_Store
Thumbs.db
desktop.ini

# 忽略开发环境文件
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 忽略编辑器文件
.vscode/
.idea/
*.swp
*.swo
*~

# 忽略操作系统临时文件
*.tmp
*.temp

# 忽略敏感信息
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 忽略密钥文件
*.key
*.pem
*.pub
Y
Y.pub

# 忽略备份文件
*.bak
*.backup

# 忽略编译输出
dist/
build/
out/

# 忽略日志文件
*.log
logs/

# 忽略测试覆盖率
coverage/
.nyc_output/

# 忽略缓存
.cache/
.tmp/

# 忽略数据库文件
*.db
*.sqlite3

# 忽略依赖锁定文件（根据实际需要）
# package-lock.json
# yarn.lock

# 忽略上传的图片等资源（如果使用CDN）
# uploads/
